// License Engine — Prisma schema.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum AdminRole {
  owner
  operator
  readonly
}

enum RevocationStrategy {
  recheck
  refresh
}

enum SigningAlgorithm {
  Ed25519
}

enum ExternalSource {
  manual
  stripe
  paddle
}

enum LicenseType {
  subscription
  perpetual
}

enum LicenseStatus {
  active
  revoked
  expired
}

enum BindingType {
  domain
  device
  account
  installation
}

enum ActivationStatus {
  active
  released
}

enum AuditActorType {
  admin
  api_key
  system
  anonymous
}

// -----------------------------------------------------------------------------
// Admin
// -----------------------------------------------------------------------------

model AdminUser {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  totpSecret       String
  /// Last TOTP step (Unix-time / 30s) successfully consumed by this user.
  /// Replay defense: a code valid for window N may not be used twice.
  totpLastUsedStep BigInt    @default(0)
  role             AdminRole @default(owner)
  createdAt        DateTime  @default(now())
  lastLoginAt      DateTime?

  @@index([email])
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  /// SHA-256 hex digest of the plaintext key. Plaintext is shown once on
  /// creation and never stored anywhere on the server. SHA-256 is sufficient
  /// here because the plaintext is a high-entropy random token (≥256 bit), so
  /// the password-stretching guarantees of argon2 add no value — but speed
  /// matters because we hash on every authenticated API request.
  keyHash    String    @unique
  /// Scopes as JSON string array, e.g. ["licenses:write", "licenses:revoke"].
  scopes     Json      @default("[]")
  /// Optional binding to a single license. When set, the key may only read/manage
  /// that license's activations (multi-tenant isolation — a tenant's key can't
  /// see other tenants). Null = unrestricted (tropicsoft-internal admin key).
  licenseId  String?
  license    License?  @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  @@index([revokedAt])
  @@index([licenseId])
}

// -----------------------------------------------------------------------------
// Domain: Products, Signing Keys
// -----------------------------------------------------------------------------

model Product {
  id                   String             @id @default(cuid())
  slug                 String             @unique
  name                 String
  /// Catalog of features this product offers, as JSON array of feature IDs/names.
  featureCatalog       Json               @default("[]")
  revocationStrategy   RevocationStrategy @default(recheck)
  recheckIntervalHours Int                @default(24)
  jwtLifetimeHours     Int                @default(168)
  /// Prefix for license keys of this product. Default "TROP", configurable per product
  /// or per partner branding.
  licenseKeyPrefix     String             @default("TROP")
  /// Currently active signing key for this product. Old keys remain for verification
  /// during rotation grace periods.
  activeSigningKeyId   String?            @unique
  activeSigningKey     SigningKey?        @relation("ActiveSigningKey", fields: [activeSigningKeyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  signingKeys SigningKey[] @relation("ProductSigningKeys")
  licenses    License[]

  @@index([slug])
}

model SigningKey {
  id        String           @id @default(cuid())
  /// Owning product; nullable for a global default key (Phase 3+ optional).
  productId String?
  product   Product?         @relation("ProductSigningKeys", fields: [productId], references: [id], onDelete: Cascade)
  algorithm SigningAlgorithm @default(Ed25519)
  /// Public key as raw base64, distributed via /.well-known/public-keys.
  publicKey String
  /// Private key encrypted with the KEK from KeyProvider. Format: nonce + ciphertext + tag, all base64.
  privateKeyEncrypted String
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  rotatedAt           DateTime?

  activeForProduct Product? @relation("ActiveSigningKey")

  @@index([productId, isActive])
}

// -----------------------------------------------------------------------------
// Domain: Customers, Licenses, Activations
// -----------------------------------------------------------------------------

model Customer {
  id      String  @id @default(cuid())
  /// Always stored lowercase-trimmed. UNIQUE so portal-login lookup is
  /// deterministic and to prevent accidental double-creation. Service-layer
  /// must normalize email before insert/update/lookup.
  email   String  @unique
  name    String
  company String?
  notes   String?
  /// Reference into an external system (e.g. Stripe customer id) for sync.
  externalRef    String?
  externalSource ExternalSource @default(manual)

  /// Phase-6 self-service portal: argon2id password hash. Null until the
  /// customer completes the initial-setup flow via emailed token.
  passwordHash      String?
  /// When the customer first proved control of the email (initial-password set).
  emailVerifiedAt   DateTime?
  /// Bookkeeping for the portal session: last successful login.
  portalLastLoginAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  licenses  License[]
  authTokens CustomerAuthToken[]

  @@unique([externalSource, externalRef], name: "externalRef_unique")
  @@index([externalRef])
}

enum CustomerAuthTokenPurpose {
  set_initial_password
  reset_password
}

model CustomerAuthToken {
  id         String                   @id @default(cuid())
  customerId String
  customer   Customer                 @relation(fields: [customerId], references: [id], onDelete: Cascade)
  /// SHA-256 hex digest of the raw token. Raw token only ever lives in the
  /// emailed link — server never stores plaintext.
  tokenHash  String                   @unique
  purpose    CustomerAuthTokenPurpose
  createdAt  DateTime                 @default(now())
  expiresAt  DateTime
  usedAt     DateTime?

  @@index([customerId, purpose])
  @@index([expiresAt])
}

model License {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  /// End-user-visible license key, format e.g. TROP-A1B2-C3D4-E5F6-G7H8.
  licenseKey String      @unique
  type       LicenseType @default(subscription)
  /// null = perpetual or no upper bound; otherwise the license expires at this point.
  expiresAt  DateTime?

  /// Active feature flags as JSON array, must be a subset of Product.featureCatalog.
  featureFlags Json @default("[]")
  /// Binding policy as JSON object describing required binding types, max activations
  /// per type, and AND/OR composition rules.
  bindingPolicy Json @default("{}")

  status           LicenseStatus @default(active)
  revokedAt        DateTime?
  revocationReason String?

  /// Reference into an external system (e.g. Stripe subscription id) for sync.
  externalRef    String?
  externalSource ExternalSource @default(manual)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activations Activation[]
  apiKeys     ApiKey[]

  @@unique([externalSource, externalRef], name: "externalRef_unique")
  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@index([externalRef])
}

model Activation {
  id          String      @id @default(cuid())
  licenseId   String
  license     License     @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  bindingType BindingType
  /// SHA-256 hash of the binding value (domain, device fingerprint, etc.). Never stored in plaintext.
  bindingValueHash String
  /// Non-sensitive metadata about the binding, e.g. browser name or OS, as JSON.
  bindingValueMetadata Json @default("{}")

  activatedAt DateTime         @default(now())
  lastSeenAt  DateTime         @default(now())
  status      ActivationStatus @default(active)
  releasedAt  DateTime?

  @@unique([licenseId, bindingType, bindingValueHash], name: "binding_unique")
  @@index([licenseId])
  @@index([bindingValueHash])
}

// -----------------------------------------------------------------------------
// Audit
// -----------------------------------------------------------------------------

model AuditLog {
  id        String         @id @default(cuid())
  timestamp DateTime       @default(now())
  /// Event identifier, e.g. "license.created", "license.revoked", "admin.login.success".
  eventType String
  actorType AuditActorType
  /// AdminUser.id or ApiKey.id depending on actorType; null for system/anonymous events.
  actorId   String?
  /// Target entity type (e.g. "License", "Product"); null for events without a target.
  targetType String?
  targetId   String?
  /// Free-form metadata about the event. Must not contain plaintext secrets.
  metadata   Json @default("{}")
  /// SHA-256 hash of the source IP. Never store IPs in cleartext (DSGVO).
  ipHash     String?

  @@index([timestamp])
  @@index([eventType])
  @@index([targetType, targetId])
  @@index([actorType, actorId])
}
