{
  "name": "license-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-Product license server (root workspace).",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @license-engine/server dev",
    "build": "pnpm --filter @license-engine/server build",
    "start": "pnpm --filter @license-engine/server start",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm --filter @license-engine/shared-types build && pnpm -r run typecheck",
    "test": "pnpm --filter @license-engine/shared-types build && pnpm -r run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "admin:bootstrap": "pnpm --filter @license-engine/server admin:bootstrap"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
