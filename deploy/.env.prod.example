# =============================================================================
# License Engine — Production .env (Template)
#
# Auf dem Server ablegen als /opt/stacks/license-engine/.env (chmod 600).
# NIEMALS committen. Echte Secrets nur auf dem Server.
#
# Generatoren (lokal ausführen, Werte hier eintragen):
#   ENCRYPTION_KEY  : openssl rand -base64 32   (exakt 32 Byte nach base64-decode)
#   NEXTAUTH_SECRET : openssl rand -base64 48
#   POSTGRES_PASSWORD: openssl rand -base64 24
# =============================================================================

# --- Datenbank ---------------------------------------------------------------
# Wird vom Postgres-Container UND (via compose) für DATABASE_URL genutzt.
# DATABASE_URL selbst setzt die compose.yaml automatisch auf den DB-Service —
# hier NICHT nötig.
POSTGRES_PASSWORD="CHANGE_ME_openssl_rand_base64_24"

# --- Crypto / JWT ------------------------------------------------------------
ENCRYPTION_KEY="CHANGE_ME_openssl_rand_base64_32"
JWT_ISSUER="license.tropicsoft.de"

# --- App ---------------------------------------------------------------------
APP_BASE_URL="https://license.tropicsoft.de"
NODE_ENV="production"

# --- NextAuth (Admin-Login) --------------------------------------------------
NEXTAUTH_SECRET="CHANGE_ME_openssl_rand_base64_48"
NEXTAUTH_URL="https://license.tropicsoft.de"

# --- Reverse-Proxy -----------------------------------------------------------
# Prod hinter NGX Proxy Manager, kein Host-Port -> Proxy-Header vertrauen.
TRUST_PROXY_HEADERS="true"

# --- Health-Endpoint ---------------------------------------------------------
# Gate-Token für /api/health. Gesetzt -> Endpoint von außen unsichtbar (404),
# nur mit Token (Header x-health-token oder ?token=) erreichbar. Der Docker-
# Healthcheck sendet ihn automatisch. Generator: openssl rand -hex 24
HEALTH_CHECK_TOKEN="CHANGE_ME_openssl_rand_hex_24"

# --- Mail (SMTP, mailcow) ----------------------------------------------------
SMTP_HOST="mail.ts-mailserver.de"
SMTP_PORT="465"
SMTP_USER="licensing@tropicsoft.de"
SMTP_PASSWORD="CHANGE_ME_mailcow_app_password"
SMTP_FROM="tropicsoft Lizenz-Portal <licensing@tropicsoft.de>"

# --- Logging -----------------------------------------------------------------
LOG_LEVEL="info"

# --- Admin-Bootstrap (NUR fuer den einmaligen Erst-Bootstrap setzen, danach
#     wieder aus der .env entfernen) -----------------------------------------
# ADMIN_BOOTSTRAP_EMAIL="jan@tropicsoft.de"
# ADMIN_BOOTSTRAP_PASSWORD="CHANGE_ME_min_12_chars"
