# =============================================================================
# License Engine — Environment Variables (Template)
# Kopiere diese Datei nach `.env` und ersetze die Platzhalter mit echten Werten.
# Niemals echte Secrets committen.
#
# Schnellstart-Generatoren:
#   ENCRYPTION_KEY  : openssl rand -base64 32
#   NEXTAUTH_SECRET : openssl rand -base64 32
# =============================================================================

# -----------------------------------------------------------------------------
# Datenbank (PostgreSQL 16)
# -----------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# Bei docker-compose: HOST = postgres (Service-Name), bei lokal direkt = localhost
DATABASE_URL="postgresql://license_engine:license_engine_dev@localhost:5432/license_engine?schema=public"

# Wird nur vom docker-compose-Postgres-Container gelesen.
POSTGRES_PASSWORD="license_engine_dev"

# -----------------------------------------------------------------------------
# JWT / Crypto
# -----------------------------------------------------------------------------
# Master-Encryption-Key (KEK) zum Verschlüsseln der in der DB gespeicherten
# Ed25519-Private-Keys. Entweder Inline-Wert (Base64, exakt 32 Byte) ODER Datei-Pfad.
# Wenn beides gesetzt: ENCRYPTION_KEY_FILE hat Vorrang.
ENCRYPTION_KEY="CHANGE_ME_base64_32_bytes"
# ENCRYPTION_KEY_FILE="/run/secrets/license_engine_kek"

# JWT-Issuer-Claim (`iss`), erscheint in jedem ausgestellten Token.
JWT_ISSUER="license.tropicsoft.de"

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Öffentliche Base-URL, unter der die App erreichbar ist (ohne Trailing-Slash).
APP_BASE_URL="http://localhost:3000"

# Node-Env (`development` | `production` | `test`)
NODE_ENV="development"

# -----------------------------------------------------------------------------
# NextAuth (Admin-Login)
# -----------------------------------------------------------------------------
# Mind. 32 Zeichen Random.
NEXTAUTH_SECRET="CHANGE_ME_random_32_chars_min"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Admin-Bootstrap
# -----------------------------------------------------------------------------
# Wird vom CLI-Bootstrap-Skript verwendet, um den initialen Owner-Account anzulegen.
# Mindestens 12 Zeichen. Nach erfolgreichem Bootstrap aus der `.env` entfernen.
ADMIN_BOOTSTRAP_EMAIL="jan@tropicsoft.de"
ADMIN_BOOTSTRAP_PASSWORD="CHANGE_ME_strong_password_min_12"

# -----------------------------------------------------------------------------
# Mail-Versand (SMTP)
# -----------------------------------------------------------------------------
# Optional — wenn alle fünf gesetzt sind, nutzt das System SmtpMailSender.
# Wenn nicht gesetzt, fällt es auf ConsoleMailSender zurück (Mail-Inhalt
# erscheint im pino-Log, kein echter Versand).
SMTP_HOST="mail.example.com"
SMTP_PORT="465"                       # 465 = implicit TLS, 587 = STARTTLS
SMTP_USER="licensing@example.com"
SMTP_PASSWORD="CHANGE_ME_app_password"
SMTP_FROM="tropicsoft Lizenz-Portal <licensing@example.com>"

# Optional: erzwinge einen bestimmten Transport. Sonst auto (smtp wenn voll konfiguriert).
# MAIL_TRANSPORT="console"  # für lokale Tests ohne Mail-Versand
# MAIL_TRANSPORT="smtp"     # zwingt SMTP, scheitert wenn SMTP_* unvollständig

# -----------------------------------------------------------------------------
# Logging / Monitoring
# -----------------------------------------------------------------------------
LOG_LEVEL="info"  # trace | debug | info | warn | error | fatal
